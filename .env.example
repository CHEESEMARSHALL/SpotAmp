# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# PLEX_BASE_URL: The base URL of your Plex Media Server (e.g., http://192.168.1.100:32400)
PLEX_BASE_URL=http://localhost:32400

# PLEX_TOKEN: Your Plex Access Token used to authenticate requests
PLEX_TOKEN=YOUR_PLEX_TOKEN

# LASTFM_API_KEY / LASTFM_API_SECRET: Optional Last.fm application credentials.
# Leave placeholders to disable Last.fm network scrobbling until configured.
LASTFM_API_KEY=YOUR_LASTFM_API_KEY
LASTFM_API_SECRET=YOUR_LASTFM_API_SECRET

